{
    "name": "iiitmanipur/tnp-portal",
    "description": "Training and Placement Portal for IIIT Manipur",
    "require": {
        "php": "^7.3 || ^8.0 || ^8.2",
        "aws/aws-sdk-php": "^3.200",
        "enshrined/svg-sanitize": "^0.15",
        "google/apiclient": "^2.0",
        "guzzlehttp/guzzle": "^7.4",
        "lcobucci/jwt": "^4.1",
        "league/oauth2-client": "^2.6",
        "league/oauth2-google": "^4.0",
        "league/oauth2-linkedin": "^5.1",
        "monolog/monolog": "^2.3",
        "php-di/php-di": "^6.4",
        "phpmailer/phpmailer": "^6.10",
        "phpoffice/phpspreadsheet": "^1.18",
        "ramsey/uuid": "^4.2",
        "respect/validation": "^2.2",
        "smalot/pdfparser": "^2.5",
        "vlucas/phpdotenv": "^5.4"
    },
    "autoload": {
        "psr-4": {
            "TnpPortal\\": "utils/TnpPortal/",
            "TnpPortal\\Api\\": "api/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6",
        "zircote/swagger-php": "^5.1"
    },
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs --standard=PSR12 ./api ./utils",
        "generate-docs": "php vendor/bin/openapi --output ./docs/swagger.json ./api"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
